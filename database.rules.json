{
  "rules": {
    ".read": "auth != null",
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "roomCodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "roomMeta": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "userMapHistory": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$roomId": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "_serverRoomIds": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "servers": {
      ".indexOn": ["joinCode"],
      "$serverId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "serverMembers": {
      "$serverId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$uid": {
          ".write": "auth != null"
        }
      }
    },
    "userServers": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$serverId": {
          ".write": "auth != null"
        }
      }
    },
    "serverCodes": {
      ".indexOn": ["serverId"],
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null"
      }
    },
    "serverRooms": {
      "$serverId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$roomId": {
          ".write": "auth != null"
        }
      }
    },
    "serverMessages": {
      "$serverId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$roomId": {
          "$messageId": {
            ".write": "auth != null"
          }
        }
      }
    },
    "serverVoiceState": {
      "$serverId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$roomId": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "serverMapRooms": {
      "$serverId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$roomId": {
          ".write": "auth != null"
        }
      }
    }
  }
}
